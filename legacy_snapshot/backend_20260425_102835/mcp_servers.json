{
  "servers": {
    "filesystem_workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\GitHub\\agentic-nexus",
        "C:\\Users\\l1234\\.codex\\skills"
      ],
      "description": "Read/write project workspace and local codex skills directory"
    },
    "knowledge_memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "description": "Knowledge graph memory tools for entities, relations, and observations"
    },
    "sequential_thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Structured reasoning tool for decomposition and verification"
    },
    "playwright_browser": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless",
        "--isolated",
        "--output-mode",
        "stdout",
        "--output-dir",
        ".playwright-mcp"
      ],
      "description": "Browser automation and snapshot testing via Playwright MCP"
    },
    "everything_lab": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ],
      "description": "Comprehensive MCP protocol sandbox server for extended tools/resources/prompts"
    },
    "pdf_reader": {
      "command": "npx",
      "args": [
        "-y",
        "--silent",
        "--registry=https://registry.npmjs.org/",
        "@modelcontextprotocol/server-pdf",
        "--stdio"
      ],
      "description": "Interactive PDF tools for parsing and page-level extraction"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "description": "GitHub repository/file/issues/search MCP tools"
    },
    "tavily_search": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "$TAVILY_API_KEY"
      },
      "description": "Tavily web search/extract/map/crawl MCP tools"
    }
  }
}
