{
  "servers": {
    "web_search": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "description": "网页抓取工具"
    },
    "brave_search": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "$BRAVE_API_KEY"
      },
      "description": "Brave搜索引擎"
    }
  }
}
