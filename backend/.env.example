# 数据库
POSTGRES_URL=postgresql+asyncpg://agent_user:agent_pass@localhost:15432/agent_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL=deepseek-v3.2

# 认证（必填）— 格式：token1:user_id1,token2:user_id2
# 生成：openssl rand -hex 32
TASK_AUTH_TOKENS=
ADMIN_USER_IDS=

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
CORS_ALLOW_ORIGINS=https://your-domain.example

# 限流
TASK_CREATE_RATE_LIMIT_PER_MINUTE=100
DISABLE_RATE_LIMIT=false

# 并发控制
MAX_CONCURRENT_LLM_CALLS=5
MAX_CONCURRENT_WRITERS=3
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
ENABLE_TEA_PROTOCOL=false
TEA_PROTOCOL_VERSION=1.0
ENABLE_TOOL_LIFECYCLE=false
TOOL_LIFECYCLE_MAX_RECORDS=1000
ENABLE_TOOL_MANAGER_AGENT=false
ENABLE_MCTS_SHADOW=false
MCTS_UCB_C=1.4

# WebSocket
WS_ALLOW_QUERY_TOKEN_FALLBACK=false

# RAG（可选）
RAG_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Memory
MEMORY_ENABLED=false
MEMORY_PROVIDER_TIMEOUT_SECONDS=15
MEMORY_SESSION_ONLY_MODE=false
MEMORY_SESSION_RETENTION_SECONDS=86400
MEMORY_AUTO_COGNIFY_ON_STORE=true
LLM_PROVIDER=openai
LLM_MODEL=deepseek/deepseek-v3.2
LLM_ENDPOINT=
LLM_API_KEY=
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DATABASE_PROVIDER=lancedb
VECTOR_DATASET_DATABASE_HANDLER=lancedb
ENABLE_BACKEND_ACCESS_CONTROL=false
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_NAMESPACE_PREFIX=task
